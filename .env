# ===== Lab 4 Runtime Settings =====
RESBOT_MODEL_NAME=google/flan-t5-large
RESBOT_LLM_TIMEOUT_SEC=75
RESBOT_LLM_MAX_RETRIES=2
RESBOT_LLM_BACKOFF_BASE_SEC=1.5
RESBOT_LLM_FALLBACK_MESSAGE=ResilienceBot could not generate a reliable response right now. Please retry or consult the runbook.
# ===== Day 2 Lab 1: RAG Pipeline =====
RESBOT_EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
RESBOT_DOCS_DIR=data/docs
RESBOT_INDEX_DIR=data/index
RESBOT_CHUNK_SIZE=200
RESBOT_CHUNK_OVERLAP=40
RESBOT_RETRIEVAL_TOP_K=3
